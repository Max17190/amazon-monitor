# Overlay these values on endpoint.env for the calibrated low-latency profile.
# A requested interval below five seconds fails closed to five seconds unless
# an exact, unexpired direct-route calibration exists in Postgres.
MONITOR_FAST_ALERT=true
POLL_INTERVAL_SECONDS=0.5
FAST_ALERT_CONFIRM_EVERY_POLLS=12
ALERT_OUTBOX_FALLBACK_POLL_SECONDS=1
ALERT_CONNECTION_WARM_SECONDS=90
TVSS_CALIBRATION_VALIDITY_SECONDS=86400
