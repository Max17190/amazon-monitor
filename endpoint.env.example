# What to monitor + where alerts go.
# Each group lists 1+ ASINs and 1+ webhook target names. Webhook names
# must match WEBHOOK_<NAME>_URL entries below.
MONITOR_CONFIG_JSON={"groups":[{"name":"GPUs","asins":["B0DT7L98J1"],"webhooks":["DISCORD"]}]}

# Discord webhook (default kind). Add WEBHOOK_<NAME>_ROLE_ID for role pings.
WEBHOOK_DISCORD_URL=https://discord.com/api/webhooks/REPLACE_ME
WEBHOOK_DISCORD_ROLE_ID=

# Generic webhook example — uncomment to forward alerts as JSON POSTs to
# Slack relays, Zapier, n8n, or your own service.
# WEBHOOK_AUTOMATION_URL=https://example.com/restock
# WEBHOOK_AUTOMATION_KIND=generic

# Marketplace + currency. Defaults are US.
TVSS_MARKETPLACE_ID=ATVPDKIKX0DER
TVSS_DOMAIN=amazon.com
TVSS_CURRENCY=USD

# Durable identity + Postgres authority.
DATABASE_URL=postgresql://monitor:monitor@postgres:5432/amazon_monitor
MONITOR_ID=primary-us
TVSS_CREDENTIAL_ID=primary-amazon-account

# Polling.
# One credential-wide request-start cadence for a single batch of up to 20 ASINs.
# Run `python cadence_canary.py --confirm` to validate a sustainable interval.
POLL_INTERVAL_SECONDS=5.0
TVSS_CALIBRATION_VALIDITY_SECONDS=86400
TVSS_429_COOLDOWN_SECONDS=900
TVSS_MAX_COOLDOWN_SECONDS=3600
TVSS_MAX_INTERVAL_SECONDS=300
TVSS_RECOVERY_SUCCESS_COUNT=120
TVSS_INTERVAL_DECREMENT=0.25
TVSS_LEADER_LEASE_SECONDS=30
TVSS_LEADER_RENEW_SECONDS=10

# Other.
MONITOR_REQUIRE_AMAZON_SELLER=true
# Fast alert: notify on batch OOS to IN without waiting for product() confirm.
# Seller filter (if enabled) runs async and only logs; does not retract.
MONITOR_FAST_ALERT=false
FAST_ALERT_CONFIRM_EVERY_POLLS=12
MONITOR_USE_BATCH=true
TVSS_TIMEOUT=5
AUTH_FAILURE_GRACE_SECONDS=30
LOG_LEVEL=INFO

# Durable alert delivery and operations.
ALERT_WORKER_CONCURRENCY=32
ALERT_TARGET_CONCURRENCY=2
ALERT_MAX_ATTEMPTS=10
ALERT_MAX_AGE_SECONDS=900
ALERT_MAX_BACKOFF_SECONDS=60
ALERT_LEASE_SECONDS=30
ALERT_OUTBOX_FALLBACK_POLL_SECONDS=1
ALERT_CONNECTION_WARM_SECONDS=90
ALERT_CONNECT_TIMEOUT_SECONDS=1
ALERT_READ_TIMEOUT_SECONDS=2
ALERT_ATTEMPT_TIMEOUT_SECONDS=3
ALERT_CIRCUIT_FAILURE_THRESHOLD=5
ALERT_CIRCUIT_OPEN_SECONDS=60
ALERT_DEAD_LETTER_RETENTION_DAYS=30
STOCK_CONFIRM_TTL_SECONDS=90
STOCK_OOS_REARM_COUNT=2
METRICS_PORT=9090
# OTEL_EXPORTER_OTLP_ENDPOINT=http://collector:4317

# Optional ranked proxy pool. Logs contain opaque route IDs only.
# Entries may be full URLs or host:port:user:password.
# PROXY_URL=http://USER:PASS@HOST:PORT
# PROXY_URLS_JSON=["HOST:PORT:USER:PASS","http://USER:PASS@HOST:PORT"]
# PROXY_POOL_FILE=.firecrawl/webshare-proxies.txt
# PROXY_MODE=fallback keeps direct as the healthy primary route.
# PROXY_MODE=fallback
