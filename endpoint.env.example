# What to monitor + where alerts go.
# Each group lists 1+ ASINs and 1+ webhook target names. Webhook names
# must match WEBHOOK_<NAME>_URL entries below.
MONITOR_CONFIG_JSON={"groups":[{"name":"GPUs","asins":["B0DT7L98J1"],"webhooks":["DISCORD"]}]}

# Discord webhook (default kind). Add WEBHOOK_<NAME>_ROLE_ID for role pings.
WEBHOOK_DISCORD_URL=https://discord.com/api/webhooks/REPLACE_ME
WEBHOOK_DISCORD_ROLE_ID=

# Generic webhook example — uncomment to forward alerts as JSON POSTs to
# Slack relays, Zapier, n8n, or your own service.
# WEBHOOK_AUTOMATION_URL=https://example.com/restock
# WEBHOOK_AUTOMATION_KIND=generic

# Marketplace + currency. Defaults are US.
TVSS_MARKETPLACE_ID=ATVPDKIKX0DER
TVSS_DOMAIN=amazon.com
TVSS_CURRENCY=USD

# Polling.
# Per-ASIN cadence ≈ ceil(num_asins / TVSS_BATCH_CHUNK_SIZE) * POLL_INTERVAL_SECONDS.
# Run `python benchmark.py --confirm` to find the lowest interval your cookies
# tolerate without 429s; paste the calibrated values back here.
POLL_INTERVAL_SECONDS=2.0

# Amazon hard-rejects 51+ ASINs per request with HTTP 400. Keep at 50.
TVSS_BATCH_CHUNK_SIZE=50

# Parallel chunks. Empirically, 4 parallel chunks at 1s caused 84% 429s in 75s,
# so default to 1 (sequential). Increase only if benchmark confirms cookies tolerate it.
TVSS_BATCH_CONCURRENCY=1

# Other.
MONITOR_REQUIRE_AMAZON_SELLER=true
# Fast alert: notify on batch OOS→IN without waiting for product() confirm.
# Seller filter (if enabled) runs async and only logs; does not retract.
MONITOR_FAST_ALERT=true
MONITOR_USE_BATCH=true
TVSS_TIMEOUT=5
AUTH_FAILURE_GRACE_SECONDS=30
LOG_LEVEL=INFO

# Optional residential proxy (credentials never logged).
# PROXY_MODE=fallback (default): direct egress until TVSS 429s, then proxy.
# PROXY_MODE=always: always use PROXY_URL (higher latency).
# PROXY_URL=http://USER:PASS@HOST:PORT
# PROXY_MODE=fallback
